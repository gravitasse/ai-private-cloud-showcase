# VPS Docker Edition Environment Variables

# The domain name where the services will be hosted (if exposed via reverse proxy)
DOMAIN_NAME=localhost

# A highly secure random string for Open WebUI session encryption
# Generate one using: openssl rand -base64 32
WEBUI_SECRET_KEY=super_secure_random_string_replace_me

# Timezone for n8n automated workflows
TIMEZONE=America/Los_Angeles
